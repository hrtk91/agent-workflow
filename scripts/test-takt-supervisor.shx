#!/usr/bin/env shx

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
TMP_DIR=$(mktemp -d)
WORKER="$TMP_DIR/agent-workflow-worker"
ORIG_HOME=${HOME:-}
export GOPATH="${GOPATH:-$ORIG_HOME/go}"
export GOMODCACHE="${GOMODCACHE:-$GOPATH/pkg/mod}"
export GOCACHE="$TMP_DIR/go-build-cache"
export GOFLAGS="${GOFLAGS:--buildvcs=false}"
export HOME="$TMP_DIR/home"
export PATH="$TMP_DIR/bin:$PATH"

cleanup() {
  if [ -n "${LEAK_REPO:-}" ] && [ -n "${LEAK_WT:-}" ] {
    git -C "$LEAK_REPO" worktree remove --force "$LEAK_WT" >/dev/null 2>&1 || true
    git -C "$LEAK_REPO" worktree prune >/dev/null 2>&1 || true
  }
  HOME="$ORIG_HOME" rm -rf "$TMP_DIR"
}
trap cleanup EXIT INT TERM

mkdir -p "$TMP_DIR/bin" "$HOME"

printf '%s\n' \
  '#!/usr/bin/env sh' \
  'set -eu' \
  'if [ -n "${TAKT_FAKE_LOG:-}" ]; then' \
  '  printf "%s\n" "$@" >>"$TAKT_FAKE_LOG"' \
  'fi' \
  'case "${TAKT_FAKE_MODE:-success}" in' \
  '  success)' \
  '    echo "fake takt success"' \
  '    exit 0' \
  '    ;;' \
  '  fail)' \
  '    echo "fake takt failed" >&2' \
  '    exit 42' \
  '    ;;' \
  '  sleep)' \
  '    sleep 30' \
  '    exit 0' \
  '    ;;' \
  '  noverify)' \
  '    echo "git commit --no-verify"' \
  '    exit 0' \
  '    ;;' \
  '  worktree_leak)' \
  '    git worktree add --detach "$TAKT_FAKE_WORKTREE" HEAD >/dev/null' \
  '    echo "created worktree $TAKT_FAKE_WORKTREE"' \
  '    exit 0' \
  '    ;;' \
  '  *)' \
  '    echo "unknown TAKT_FAKE_MODE=$TAKT_FAKE_MODE" >&2' \
  '    exit 99' \
  '    ;;' \
  'esac' \
  >"$TMP_DIR/bin/takt"
chmod +x "$TMP_DIR/bin/takt"

fail() {
  echo "not ok - $1" >&2
  exit 1
}

pass() {
  echo "ok - $1"
}

assert_contains() {
  file=$1
  needle=$2
  if ! grep -F -- "$needle" "$file" >/dev/null {
    echo "expected to find: $needle" >&2
    echo "in file: $file" >&2
    sed -n '1,220p' "$file" >&2 || true
    exit 1
  }
}

assert_not_exists() {
  path=$1
  if [ -e "$path" ] {
    fail "unexpected path exists: $path"
  }
}

new_repo() {
  name=$1
  repo="$TMP_DIR/repos/$name"
  mkdir -p "$repo/.takt/workflows"
  git -C "$repo" init -q
  git -C "$repo" config user.name "agent-workflow-test"
  git -C "$repo" config user.email "agent-workflow-test@example.invalid"
  printf 'tasks: []\n' >"$repo/.takt/tasks.yaml"
  printf 'name: default\nsteps: []\n' >"$repo/.takt/workflows/default.yaml"
  printf 'hello\n' >"$repo/README.md"
  git -C "$repo" add .
  git -C "$repo" commit -q -m initial
  printf '%s\n' "$repo"
}

run_expect_success() {
  out=$1
  err=$2
  shift 2
  "$WORKER" "$@" >"$out" 2>"$err"
}

run_expect_failure() {
  out=$1
  err=$2
  shift 2
  set +e
  "$WORKER" "$@" >"$out" 2>"$err"
  rc=$?
  set -e
  if [ "$rc" -eq 0 ] {
    fail "command unexpectedly succeeded: $*"
  }
}

summary_path() {
  tail -n 1 "$1"
}

cd "$ROOT_DIR"
go build -o "$WORKER" ./cmd/worker

test_requires_takt_args() {
  repo=$(new_repo requires_takt_args)
  out="$TMP_DIR/requires.out"
  err="$TMP_DIR/requires.err"
  run_expect_failure "$out" "$err" \
    -mode dry-run \
    -kind takt \
    -repo "$repo" \
    -verify-command "true"
  assert_contains "$err" "taktArgs is required"
  pass "requires explicit takt args"
}

test_pipeline_args_and_missing_verifier() {
  repo=$(new_repo missing_verifier)
  export TAKT_FAKE_MODE=success
  export TAKT_FAKE_LOG="$TMP_DIR/missing-verifier.args"
  out="$TMP_DIR/missing-verifier.out"
  err="$TMP_DIR/missing-verifier.err"
  run_expect_success "$out" "$err" \
    -mode dry-run \
    -kind takt \
    -repo "$repo" \
    -takt-args "--pipeline --skip-git --quiet --workflow default --task smoke"
  summary=$(summary_path "$out")
  assert_contains "$summary" '- verifier_passed: `false`'
  assert_contains "$summary" "verifyCommand is required before a takt run can be marked done"
  assert_contains "$summary" '- command: `takt --pipeline --skip-git --quiet --workflow default --task smoke`'
  assert_contains "$TAKT_FAKE_LOG" "--pipeline"
  assert_contains "$TAKT_FAKE_LOG" "--skip-git"
  pass "pipeline args are passed and verifier is required"
}

test_success_with_verifier() {
  repo=$(new_repo success_with_verifier)
  export TAKT_FAKE_MODE=success
  export TAKT_FAKE_LOG="$TMP_DIR/success.args"
  out="$TMP_DIR/success.out"
  err="$TMP_DIR/success.err"
  run_expect_success "$out" "$err" \
    -mode dry-run \
    -kind takt \
    -repo "$repo" \
    -takt-args "--pipeline --skip-git --quiet --workflow default --task smoke" \
    -verify-command "test -d .takt"
  summary=$(summary_path "$out")
  assert_contains "$summary" '- verifier_passed: `true`'
  pass "successful takt run passes only with explicit verifier"
}

test_takt_failure_is_not_done() {
  repo=$(new_repo takt_failure)
  export TAKT_FAKE_MODE=fail
  export TAKT_FAKE_LOG="$TMP_DIR/failure.args"
  out="$TMP_DIR/failure.out"
  err="$TMP_DIR/failure.err"
  run_expect_success "$out" "$err" \
    -mode dry-run \
    -kind takt \
    -repo "$repo" \
    -takt-args "--pipeline --skip-git --quiet --workflow default --task smoke" \
    -verify-command "test -d .takt"
  summary=$(summary_path "$out")
  assert_contains "$summary" '- verifier_passed: `false`'
  assert_contains "$summary" "takt command exited with 42"
  pass "takt non-zero exit is reported as not done"
}

test_timeout_is_not_done_and_kills_child() {
  repo=$(new_repo timeout)
  export TAKT_FAKE_MODE=sleep
  export TAKT_FAKE_LOG="$TMP_DIR/timeout.args"
  out="$TMP_DIR/timeout.out"
  err="$TMP_DIR/timeout.err"
  run_expect_success "$out" "$err" \
    -mode dry-run \
    -kind takt \
    -repo "$repo" \
    -takt-args "--pipeline --skip-git --quiet --workflow default --task smoke" \
    -timeout-seconds 1 \
    -verify-command "test -d .takt"
  summary=$(summary_path "$out")
  assert_contains "$summary" '- command_timed_out: `true`'
  assert_contains "$summary" "takt command timed out"
  pass "timeout is reported as not done"
}

test_dirty_repo_rejected_before_takt() {
  repo=$(new_repo dirty_repo)
  printf 'dirty\n' >>"$repo/README.md"
  export TAKT_FAKE_MODE=success
  export TAKT_FAKE_LOG="$TMP_DIR/dirty.args"
  out="$TMP_DIR/dirty.out"
  err="$TMP_DIR/dirty.err"
  run_expect_failure "$out" "$err" \
    -mode dry-run \
    -kind takt \
    -repo "$repo" \
    -takt-args "--pipeline --skip-git --quiet --workflow default --task smoke" \
    -verify-command "test -d .takt"
  assert_contains "$err" "repository has uncommitted changes"
  assert_not_exists "$TAKT_FAKE_LOG"
  pass "dirty repo is rejected before invoking takt"
}

test_lock_conflict_rejects_second_run() {
  repo=$(new_repo lock_conflict)
  lock="$TMP_DIR/held.lock"
  mkdir -p "$(dirname "$lock")"
  exec 9>"$lock"
  flock -n 9
  export TAKT_FAKE_MODE=success
  export TAKT_FAKE_LOG="$TMP_DIR/lock.args"
  out="$TMP_DIR/lock.out"
  err="$TMP_DIR/lock.err"
  run_expect_failure "$out" "$err" \
    -mode dry-run \
    -kind takt \
    -repo "$repo" \
    -takt-lock "$lock" \
    -takt-args "--pipeline --skip-git --quiet --workflow default --task smoke" \
    -verify-command "test -d .takt"
  assert_contains "$err" "another takt workflow is already running"
  assert_not_exists "$TAKT_FAKE_LOG"
  flock -u 9
  pass "lock conflict rejects concurrent takt run"
}

test_no_verify_output_is_not_done() {
  repo=$(new_repo noverify)
  export TAKT_FAKE_MODE=noverify
  export TAKT_FAKE_LOG="$TMP_DIR/noverify.args"
  out="$TMP_DIR/noverify.out"
  err="$TMP_DIR/noverify.err"
  run_expect_success "$out" "$err" \
    -mode dry-run \
    -kind takt \
    -repo "$repo" \
    -takt-args "--pipeline --skip-git --quiet --workflow default --task smoke" \
    -verify-command "test -d .takt"
  summary=$(summary_path "$out")
  assert_contains "$summary" '- verifier_passed: `false`'
  assert_contains "$summary" '`--no-verify` appeared in takt output'
  pass "--no-verify in takt output is rejected"
}

test_worktree_leak_is_not_done() {
  repo=$(new_repo worktree_leak)
  LEAK_REPO="$repo"
  LEAK_WT="$TMP_DIR/leaked-worktree"
  export TAKT_FAKE_MODE=worktree_leak
  export TAKT_FAKE_WORKTREE="$LEAK_WT"
  export TAKT_FAKE_LOG="$TMP_DIR/worktree.args"
  out="$TMP_DIR/worktree.out"
  err="$TMP_DIR/worktree.err"
  run_expect_success "$out" "$err" \
    -mode dry-run \
    -kind takt \
    -repo "$repo" \
    -takt-args "--pipeline --skip-git --quiet --workflow default --task smoke" \
    -verify-command "test -d .takt"
  summary=$(summary_path "$out")
  assert_contains "$summary" '- verifier_passed: `false`'
  assert_contains "$summary" "new git worktrees remain after takt run"
  git -C "$repo" worktree remove --force "$LEAK_WT" >/dev/null
  git -C "$repo" worktree prune >/dev/null
  LEAK_REPO=
  LEAK_WT=
  pass "leftover git worktree is rejected"
}

test_worktree_leak_can_be_allowed() {
  repo=$(new_repo worktree_allowed)
  LEAK_REPO="$repo"
  LEAK_WT="$TMP_DIR/allowed-worktree"
  export TAKT_FAKE_MODE=worktree_leak
  export TAKT_FAKE_WORKTREE="$LEAK_WT"
  export TAKT_FAKE_LOG="$TMP_DIR/worktree-allowed.args"
  out="$TMP_DIR/worktree-allowed.out"
  err="$TMP_DIR/worktree-allowed.err"
  run_expect_success "$out" "$err" \
    -mode dry-run \
    -kind takt \
    -repo "$repo" \
    -takt-args "--pipeline --skip-git --quiet --workflow default --task smoke" \
    -allow-new-worktrees \
    -verify-command "test -d .takt"
  summary=$(summary_path "$out")
  assert_contains "$summary" '- verifier_passed: `true`'
  git -C "$repo" worktree remove --force "$LEAK_WT" >/dev/null
  git -C "$repo" worktree prune >/dev/null
  LEAK_REPO=
  LEAK_WT=
  pass "new git worktrees can be explicitly allowed"
}

test_requires_takt_args
test_pipeline_args_and_missing_verifier
test_success_with_verifier
test_takt_failure_is_not_done
test_timeout_is_not_done_and_kills_child
test_dirty_repo_rejected_before_takt
test_lock_conflict_rejects_second_run
test_no_verify_output_is_not_done
test_worktree_leak_is_not_done
test_worktree_leak_can_be_allowed

echo "all takt supervisor tests passed"
